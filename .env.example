# =============================================================================
# Decentra Certificates — Environment Variables
# =============================================================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
#
# Никогда не коммитьте .env с реальными секретами.
# =============================================================================


# -----------------------------------------------------------------------------
# Общие настройки
# -----------------------------------------------------------------------------

# Внутреннее имя приложения. Используется в логах и заголовках.
APP_NAME=decentra-certificates

# Адрес и порт, на которых слушает Actix Web.
# Для локальной разработки — 127.0.0.1:8080.
# При запуске в Docker-контейнере замените на 0.0.0.0:8080.
BIND_ADDRESS=127.0.0.1:8080

# Количество потоков Actix Web. Рекомендуется = числу физических ядер.
# Если не задано — определяется автоматически по num_cpus.
HTTP_WORKERS=4

# Список разрешённых CORS-источников через запятую.
# По умолчанию разрешены localhost:3000 и 127.0.0.1:3000.
# Для production укажите реальный домен фронтенда.
# CORS_ORIGINS=https://your-frontend.example.com


# -----------------------------------------------------------------------------
# База данных (PostgreSQL)
# -----------------------------------------------------------------------------
# Формат: postgres://<user>:<password>@<host>:<port>/<database>
#
# Локальная разработка (docker compose up):
#   host=127.0.0.1, port=15432 (смотри docker-compose.yml → ports)
#   Но поскольку backend запускается вне Docker, используем порт 5432
#   через host-mapping. Проверьте docker-compose.yml — там публичный порт 15432,
#   поэтому для локального запуска используйте порт 15432:
#
#     DATABASE_URL=postgres://postgres:postgres@127.0.0.1:15432/decentra_certificates
#
#   В docker-compose backend сам общается с postgres по внутренней сети:
#     DATABASE_URL=postgres://postgres:postgres@postgres:5432/decentra_certificates
#
# Production: используйте управляемую БД (Supabase, RDS, Cloud SQL и т.д.).
#   Получите строку подключения в панели управления вашего провайдера.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/decentra_certificates


# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Формат: redis://<host>:<port>/<db_index>
#
# Локальная разработка (docker compose up):
#   Публичный порт Redis — 16379 (смотри docker-compose.yml → ports).
#   Для прямого запуска backend снаружи Docker:
#     REDIS_URL=redis://127.0.0.1:16379/0
#
# Production: используйте Upstash, Redis Cloud, ElastiCache и т.п.
#   URL доступен в консоли вашего Redis-провайдера.
REDIS_URL=redis://127.0.0.1:6379/0


# -----------------------------------------------------------------------------
# JWT-аутентификация
# -----------------------------------------------------------------------------
# JWT_ACCESS_SECRET и JWT_REFRESH_SECRET — произвольные случайные строки.
# Рекомендуется минимум 32 символа (64+ в production).
#
# Как сгенерировать:
#   openssl rand -hex 32
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#
# ВАЖНО: используйте разные значения для ACCESS и REFRESH.
#         Никому не передавайте эти секреты.
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# Время жизни access-токена в минутах (по умолчанию 60).
JWT_ACCESS_TTL_MINUTES=60

# Время жизни refresh-токена в днях (по умолчанию 30).
JWT_REFRESH_TTL_DAYS=30


# -----------------------------------------------------------------------------
# Выдача сертификатов
# -----------------------------------------------------------------------------

# Разрешить выдачу сертификатов при старте (можно менять через admin API).
# false = выдача отключена по умолчанию; включается через /admin/settings.
ISSUANCE_ENABLED=false

# Количество воркеров для генерации сертификатов.
# Рекомендуется = числу физических ядер или чуть меньше.
CERTIFICATE_WORKERS=4

# Параллелизм рендера PDF/PNG (обычно ≤ CERTIFICATE_WORKERS).
RENDER_PARALLELISM=4

# Масштаб рендера финального сертификата (выше = лучше качество, больше RAM/CPU).
# 1.5 — баланс качества и производительности.
CERTIFICATE_RENDER_SCALE=1.5

# Масштаб рендера превью в admin-панели.
PREVIEW_RENDER_SCALE=1.25


# -----------------------------------------------------------------------------
# Хранилище файлов (шаблоны и готовые сертификаты)
# -----------------------------------------------------------------------------
# STORAGE_DRIVER=local_fs  — файлы хранятся на диске в UPLOADS_DIR.
# STORAGE_DRIVER=s3        — файлы хранятся в S3-совместимом хранилище (AWS S3, MinIO и т.д.).
#
# Для локальной разработки используйте s3 + MinIO (поднимается через docker compose).
STORAGE_DRIVER=s3

# Путь к локальной папке для загрузок (используется только при STORAGE_DRIVER=local_fs).
UPLOADS_DIR=./uploads

# --- S3 / MinIO настройки (нужны только при STORAGE_DRIVER=s3) ---

# Имя S3-bucket. Создаётся автоматически через minio-init при docker compose up.
# Для AWS: создайте bucket в консоли https://s3.console.aws.amazon.com/
STORAGE_S3_BUCKET=decentra-certificates

# Регион S3. Для AWS выберите ближайший: us-east-1, eu-central-1, ap-southeast-1 и т.д.
# Для MinIO значение не критично, но должно быть непустым.
STORAGE_S3_REGION=us-east-1

# Опциональный префикс (папка) внутри bucket для ключей объектов.
STORAGE_S3_PREFIX=decentra-certificates

# Кастомный URL endpoint для S3-совместимых провайдеров (MinIO, Cloudflare R2, Yandex Cloud и т.д.).
# Для AWS S3 оставьте пустым или закомментируйте эту строку.
# Локальный MinIO (docker compose): http://127.0.0.1:9000  (публичный порт 19000)
# В Docker-сети (compose-to-compose): http://minio:9000
STORAGE_S3_ENDPOINT_URL=http://127.0.0.1:9000

# Использовать path-style URL вместо virtual-hosted-style.
# Обязательно true для MinIO и большинства S3-совместимых провайдеров.
# Для AWS S3 — false (или не задавать).
STORAGE_S3_FORCE_PATH_STYLE=true

# Ключи доступа к S3 / MinIO.
#
# MinIO (локально): логин/пароль из docker-compose.yml → MINIO_ROOT_USER / MINIO_ROOT_PASSWORD.
#   По умолчанию: minioadmin / minioadmin
#   Для смены — обновите docker-compose.yml и перезапустите: make down && make up
#
# AWS S3: создайте IAM-пользователя с политикой AmazonS3FullAccess (или более ограниченной),
#   затем сгенерируйте Access Key в разделе IAM → Users → Security credentials.
#   https://console.aws.amazon.com/iam/
#
# Cloudflare R2: API Tokens → Create Token → R2 Token (R2 Read & Write).
#   https://dash.cloudflare.com/ → R2 → Manage API Tokens
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin


# -----------------------------------------------------------------------------
# Telegram (опционально — gate для подписки на канал)
# -----------------------------------------------------------------------------
# Заполняйте только если хотите требовать подписку на Telegram-канал
# перед получением сертификата. Если не нужно — оставьте пустыми.

# Токен Telegram-бота. Получить у @BotFather:
#   1. Откройте @BotFather в Telegram.
#   2. Отправьте /newbot, следуйте инструкциям.
#   3. Скопируйте токен вида 123456789:AAAA...
TELEGRAM_BOT_TOKEN=

# Числовой ID Telegram-канала (отрицательное число для каналов/супергрупп).
# Как получить:
#   1. Добавьте бота в канал как администратора.
#   2. Отправьте любое сообщение в канал.
#   3. Откройте https://api.telegram.org/bot<TOKEN>/getUpdates — найдите поле chat.id.
#   Пример: -1001234567890
TELEGRAM_CHANNEL_ID=

# Публичная ссылка на канал (отображается пользователю).
TELEGRAM_CHANNEL_URL=https://t.me/channelname

# OAuth-приложение Telegram (используется для авторизации через Telegram Login Widget).
# Создаётся через @BotFather → /mybots → выберите бота → Bot Settings → Domain.
# TELEGRAM_CLIENT_ID — это числовой ID того же бота (можно узнать через getMe API).
# TELEGRAM_CLIENT_SECRET — хэш токена бота (SHA-256 от TELEGRAM_BOT_TOKEN без "bot" в начале).
TELEGRAM_CLIENT_ID=
TELEGRAM_CLIENT_SECRET=
TELEGRAM_SUBSCRIPTION_REQUIRED=false


# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
# Эти переменные не используются backend'ом. Они задаются в frontend/.env.local
# или передаются как build args в Docker.
#
# NEXT_PUBLIC_API_URL — публичный URL backend API, доступный из браузера.
# Локально: http://localhost:8080
# Production: https://api.your-domain.com
#
# Создайте файл frontend/.env.local:
#   NEXT_PUBLIC_API_URL=http://localhost:8080
